{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://string-theory.example/schemas/knowledge-node.schema.json",
  "title": "弦上乐理知识节点",
  "type": "object",
  "required": ["id", "title", "lessonIds", "claims", "status", "reviewedAt"],
  "properties": {
    "id": { "type": "string", "pattern": "^kb\\.[a-z0-9.-]+$" },
    "title": { "type": "string", "minLength": 2 },
    "lessonIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["statement", "sourceIds"],
        "properties": {
          "statement": { "type": "string", "minLength": 8 },
          "sourceIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
          "scope": { "type": "string" }
        }
      }
    },
    "status": { "enum": ["researched", "reviewed"] },
    "reviewedAt": { "type": "string", "format": "date" }
  }
}
